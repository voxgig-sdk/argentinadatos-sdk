# BasicEstadoFlow

main: kit: flow: BasicEstadoFlow:
{
  entity: "estado",
  kind: "basic",
  name: "BasicEstadoFlow",
  step: [
    {
      input: {
        ref: "estado_ref01",
        srcdatavar: "estado_ref01_data",
        suffix: "_dt0"
      }

      op: "load",
      valid: [
        {
          apply: "TextFieldMark",
          def: {
            mark: "Mark01-estado_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicEstadoFlow"
}